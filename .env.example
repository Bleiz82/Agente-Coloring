# === Database ===
DATABASE_URL="postgresql://colorforge_app:colorforge_app_dev@localhost:5432/colorforge"
POSTGRES_PASSWORD="colorforge_dev"

# === Redis ===
REDIS_URL="redis://:colorforge_dev@localhost:6379"
REDIS_PASSWORD="colorforge_dev"

# === Qdrant ===
QDRANT_URL="http://localhost:6333"

# === API Keys (fill before M3) ===
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# === Proxy Provider (fill before M2) ===
PROXY_PROVIDER="smartproxy"
PROXY_USER=""
PROXY_PASS=""
PROXY_ENDPOINT_IT_01=""
PROXY_ENDPOINT_IT_02=""
PROXY_ENDPOINT_IT_03=""

# === Operational ===
LOG_LEVEL="INFO"
DAILY_COST_CEILING_USD="50"
COLORFORGE_ENV="development"

# === Storage ===
ASSETS_ROOT="/var/colorforge/assets"
STORAGE_STATE_ROOT="/run/colorforge/state"

# === Alerts (optional, fill if you want Telegram alerts) ===
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
